  --application-policy      (Group: Action) Set application policy (format: REQUEST-ID:OID)
  --enroll                  (Group: Action) Toggle 'Enroll' role (format: SID)
  --officer                 (Group: Action) Toggle 'ManageCertificates' role (format: SID)
  --admin                   (Group: Action) Toggle 'ManageCA' role (format: SID)
  --esc6                    (Group: Action) Enable/disable ESC6
  --esc11                   (Group: Action) Enable/disable ESC11
  --esc16                   (Group: Action) Enable/disable ESC16
