<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>{{.TargetFramework}}</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <RootNamespace>{{.ProjectName}}</RootNamespace>
    <AssemblyName>{{.ProjectName}}</AssemblyName>
    <PublishTrimmed>true</PublishTrimmed>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RuntimeIdentifier>wasi-wasm</RuntimeIdentifier>
    <UseAppHost>false</UseAppHost>
    <SelfContained>true</SelfContained>
    <MSBuildEnableWorkloadResolver>false</MSBuildEnableWorkloadResolver>
    <DefineConstants>NATIVEAOT_WASI</DefineConstants>
    <Nullable>disable</Nullable>
{{- if .AllowUnsafe}}
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
{{- end}}
    <NoWarn>$(NoWarn);CS0162;CS0168;CS0219;CS8600;CS8601;CS8602;CS8603;CS8604;CS8625;SYSLIB0050;SYSLIB0051</NoWarn>
  </PropertyGroup>

{{- if .NuGetPackages}}

  <ItemGroup>
{{- range .NuGetPackages}}
    <PackageReference Include="{{.Name}}" Version="{{.Version}}" />
{{- end}}
  </ItemGroup>
{{- end}}

{{- if .StubProjects}}

  <ItemGroup>
{{- range .StubProjects}}
    <ProjectReference Include="{{.}}" />
{{- end}}
  </ItemGroup>
{{- end}}

  <!-- NativeAOT-LLVM compiler for wasi-wasm target -->
  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.ILCompiler.LLVM" Version="10.0.0-*" />
    <PackageReference Include="runtime.linux-x64.Microsoft.DotNet.ILCompiler.LLVM" Version="10.0.0-*" />
  </ItemGroup>

  <!-- WasmForge C bridge (compiled into WASM by NativeAOT-LLVM) -->
  <ItemGroup>
    <NativeLibrary Include="bridge/wf_bridge.c" />
    <NativeLibrary Include="bridge/pinvoke_nativeaot.c" />
    <!-- Extended bridge: unprefixed-name stubs for vanilla GhostPack
         [DllImport] declarations. NativeAOT-LLVM looks up these symbols
         by their literal Win32 names (CloseHandle, LsaGetLogonSessionData,
         …) when the corresponding <DirectPInvoke> entries are declared.
         The Include patterns are conditional so projects that don't ship
         these files (e.g., the Rubeus bridge using WfHostBridge.cs with
         explicit EntryPoint = "kernel32_…") aren't affected. -->
    <NativeLibrary Include="bridge/pinvoke_secur32_ext.c" Condition="Exists('bridge/pinvoke_secur32_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_kernel32_ext.c" Condition="Exists('bridge/pinvoke_kernel32_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_advapi32_ext.c" Condition="Exists('bridge/pinvoke_advapi32_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_net_ext.c" Condition="Exists('bridge/pinvoke_net_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_env_ext.c" Condition="Exists('bridge/pinvoke_env_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_extras.c" Condition="Exists('bridge/pinvoke_extras.c')" />
    <NativeLibrary Include="bridge/pinvoke_wevtapi_ext.c" Condition="Exists('bridge/pinvoke_wevtapi_ext.c')" />
    <NativeLibrary Include="bridge/pinvoke_winspool_ext.c" Condition="Exists('bridge/pinvoke_winspool_ext.c')" />
  </ItemGroup>

  <!-- WasmForge trim preservation: keeps Assembly.GetTypes() and Type.GetProperties()
       working across NativeAOT trim. Auto-generated by internal/patch/rdxml.go. -->
  <ItemGroup Condition="Exists('Properties\WfPreserve.rd.xml')">
    <RdXmlFile Include="Properties\WfPreserve.rd.xml" />
  </ItemGroup>

  <!-- WasmForge DirectPInvoke registrations: every DllImport target in the
       source tree must be statically resolvable at link time. Auto-generated
       by internal/patch/pinvoke_scanner.go. -->
  <Import Project="Properties\WfDirectPInvoke.props" Condition="Exists('Properties\WfDirectPInvoke.props')" />

  <!-- DirectPInvoke: Windows DLLs resolved at link time -->
  <ItemGroup>
    <DirectPInvoke Include="env" />
    <DirectPInvoke Include="advapi32" />
    <DirectPInvoke Include="advapi32.dll" />
    <DirectPInvoke Include="kernel32" />
    <DirectPInvoke Include="kernel32.dll" />
    <DirectPInvoke Include="secur32" />
    <DirectPInvoke Include="secur32.dll" />
    <DirectPInvoke Include="Secur32.dll" />
    <DirectPInvoke Include="ntdll.dll" />
    <DirectPInvoke Include="cryptdll.Dll" />
    <DirectPInvoke Include="CRYPT32.DLL" />
    <DirectPInvoke Include="Netapi32.dll" />
    <DirectPInvoke Include="mpr.dll" />
    <DirectPInvoke Include="ole32.dll" />
    <DirectPInvoke Include="crypt32.dll" />
    <DirectPInvoke Include="ncrypt.dll" />
    <DirectPInvoke Include="Ncrypt.dll" />
    <DirectPInvoke Include="shlwapi.dll" />
    <DirectPInvoke Include="rpcrt4.dll" />
    <DirectPInvoke Include="Rpcrt4.dll" />
    <DirectPInvoke Include="bcrypt.dll" />
    <DirectPInvoke Include="Bcrypt.dll" />
    <DirectPInvoke Include="bcrypt" />
    <DirectPInvoke Include="wevtapi" />
    <DirectPInvoke Include="wevtapi.dll" />
    <DirectPInvoke Include="winspool" />
    <DirectPInvoke Include="winspool.drv" />
  </ItemGroup>

</Project>
